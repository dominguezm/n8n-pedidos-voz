    {
      "parameters": {
        "jsCode": "// Obtenemos los datos del nodo anterior (Gemini)\nlet textoParaHablar = '';\n\nswitch ($input.first().json.intencion)\n{\n  case 'nuevo': {\n    textoParaHablar = $input.first().json.resumen;\n    break;\n  }   \n  case 'actualizar': {\n    textoParaHablar = $input.first().json.resumen;\n    break;\n  }\n  case 'eliminar': {\n    textoParaHablar = $input.first().json.resumen;\n    break;\n  }\n  case 'error_regla': {\n    textoParaHablar = $input.first().json.mensaje_error;\n    break;\n  }\n  case 'consultar': {\n    textoParaHablar = $input.first().json.consulta.guion_lectura;\n    break;\n  }\n}\n// Devolvemos el texto listo para Kokoro\nreturn {\n  json: {\n    guion: textoParaHablar\n  }\n};"
      },
