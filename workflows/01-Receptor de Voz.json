    {
      "parameters": {
        "jsCode": "const items = $input.all();\nlet textoPedidos = \"No hay pedidos resgistrados actualemente\";\n\nif (items.length > 0 && items[0].json && Object.keys(items[0].json).length > 0)\n{\ntextoPedidos = items.map(item => `fila: ${item.json.row_number} |  fecha: ${item.json.fecha} | cliente: ${item.json.cliente} | cantidad: ${item.json.cantidad} | tipo_pedido: ${item.json.tipo_pedido} | Plato: ${item.json.plato } | detalles: ${item.json.detalles} | hora_entrega: ${item.json.hora_entrega} | pago_completo: ${item.json.pago_completo} | se_entrego_pedido: ${item.json.se_entrego_pedido} | entrego_platos: ${item.json.entrego_platos}`).join('\\n');\n}\n\nconst audioBinario = $(\"Webhook_voz\").first().binary;\n\nreturn [{\n  json: {\n    historial_pedidos: textoPedidos\n  },\n  binary: audioBinario\n}];"
      },
