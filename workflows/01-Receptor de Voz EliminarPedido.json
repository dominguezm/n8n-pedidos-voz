    {
      "parameters": {
        "jsCode": "const items = $input.all();\nlet textoPedidos = \"No hay pedidos resgistrados actualemente\";\n\nif (items.length > 0 && items[0].json && Object.keys(items[0].json).length > 0)\n{\ntextoPedidos = items.map(item => `fila: ${item.json.row_number} |  cliente: ${item.json.cliente} | Plato: ${item.json.plato } | cantidad: ${item.json.cantidad} | tipo_pedido: ${item.json.tipo_pedido} | detalles: ${item.json.detalles} | hora_entrega: ${item.json.hora_entrega} | pago_por_adelantado: ${item.json.pago_por_adelantado}`).join('\\n');\n}\n\nconst audioBinario = $(\"Webhook_voz\").first().binary;\n\nreturn [{\n  json: {\n    historial_pedidos: textoPedidos\n  },\n  binary: audioBinario\n}];"
      },
