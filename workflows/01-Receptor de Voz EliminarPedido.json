    {
      "parameters": {
        "jsCode": "// Obtenemos los datos del nodo anterior (Gemini)\nlet textoParaHablar = '';\n\nswitch ($input.first().json.intencion)\n{\n  case 'nuevo': {\n    const cliente = $input.first().json.pedidos_nuevos[0].cliente;\n    const pedidos = $input.first().json.pedidos_nuevos[0].pedidos;\n    \n    // Armamos la lista de platos con sus cantidades\n    const listaPlatos = pedidos.map(item => `${item.cantidad} ${item.tipo_pedido} ${item.plato}`).join(', y ');\n    \n    // Creamos la frase final\n    textoParaHablar = `Pedido recibido para ${cliente}. Anotando: ${listaPlatos}.`;\n    \n    \n    break;\n  }\n    \n  case 'actualizar': {\n    const updatePedidos = $input.first().json.actualizaciones;\n    \n    // Armamos la lista de platos con sus cantidades\n    const listaPedidos = updatePedidos.map(item => `${item.cliente} ${item.nuevo_cantidad} ${item.nuevo_tipo_pedido} ${item.nuevo_plato}`).join(', y ');\n    \n    // Creamos la frase final\n    textoParaHablar = ` Anotando cambios: ${listaPedidos}.`;\n    \n    break;\n  }\n  case 'eliminar': {\n    const deletePedido = $input.first().json.eliminacion;\n    textoParaHablar = `¿Estás seguro de que deseas eliminar el pedido: ${deletePedido.resumen_pedido}.}`;\n    break;\n  }\n}\n// Devolvemos el texto listo para Kokoro\nreturn {\n  json: {\n    guion: textoParaHablar\n  }\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1392,
        112
